# Server
PORT=5000
SECRET_KEY=change-me

# PLC mode: sim or modbus
PLC_MODE=sim
PLC_HOST=127.0.0.1
PLC_PORT=502
PLC_UNIT_ID=1

# Optional Modbus coil mapping overrides
PLC_COIL_MOTOR_RUN=0
PLC_COIL_PUMP_RUN=1
PLC_COIL_ALARM_HORN=2
PLC_COIL_ESTOP_LATCH=3
PLC_COIL_PRESSURE_RELIEF=4
PLC_COIL_LUBE_PUMP=5

# Predictive model persistence path
SIAS_MODEL_PATH=instance/predictor_model.pkl

# API protection
SIAS_API_TOKEN=
SIAS_UI_API_TOKEN=
